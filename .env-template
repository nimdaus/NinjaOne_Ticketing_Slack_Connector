# Copy this file to .env and fill in your values.
# The .env file is loaded by docker-compose and is never committed to version control.

# ── Admin web UI ──────────────────────────────────────────────────────────────
# Port the admin UI listens on inside the container.
ADMIN_PORT=8080

# Public base URL of the admin UI — required when running behind a reverse proxy
# or Cloudflare Tunnel so the NinjaOne OAuth callback URL resolves correctly.
# Example: https://engassist.example.com
# Leave blank for direct localhost access.
ADMIN_BASE_URL=

# ── Encryption ────────────────────────────────────────────────────────────────
# Recommended. Encrypts credentials.json and slack_config.json at rest.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Back this value up separately from the ./data/ volume — if lost, credentials
# cannot be recovered and NinjaOne + Slack setup must be re-run.
ENCRYPTION_KEY=

# ── Poller ────────────────────────────────────────────────────────────────────
# How often to check open tickets for updates (seconds).
POLL_INTERVAL=300

# How far back the board filter looks (hours). Must be >= POLL_INTERVAL / 3600.
POLL_LOOKBACK_HOURS=1

# ── Optional integrations ─────────────────────────────────────────────────────
# Uptime Kuma push URL for heartbeat monitoring. Leave blank to disable.
HEARTBEAT_URL=
